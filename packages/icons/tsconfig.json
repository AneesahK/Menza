{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "target": "ES2022",
    "outDir": "./dist",
    "sourceMap": true,
    "noEmit": false,
