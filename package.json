{
  "name": "menza-demo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter=@demo/db db:generate",
    "db:migrate": "pnpm --filter=@demo/db db:migrate",
    "db:seed": "pnpm --filter=@demo/db db:seed",
    "db:studio": "pnpm --filter=@demo/db db:studio",
    "clean": "git clean -xdf node_modules dist .next && pnpm -r run clean",
    "reset": "pnpm clean && rm pnpm-lock.yaml && pnpm install",
    "preinstall": "npx -y only-allow pnpm"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@dotenvx/dotenvx": "1.51.4",
    "@ianvs/prettier-plugin-sort-imports": "4.7.0",
    "prettier": "3.7.4",
    "prettier-plugin-tailwindcss": "0.7.2",
    "typescript": "6.0.2"
  }
}
